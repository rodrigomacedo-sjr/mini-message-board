<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head.ejs") %>

  <body>
    <%- include("../partials/header.ejs") %>

    <div class="message-detail">
      <p><%=message.content%></p>

      <div class="message-detail-footer">
        <div class="msg-info">
          <p><%=message.sender%></p>
          <p>
            <%= new Date(message.created_at).toLocaleString("pt-BR", {
              day: "2-digit",
              month: "2-digit",
              year: "numeric",
              hour: "2-digit",
              minute: "2-digit"
            }) %>
          </p>
        </div>
        <a class="delete" data-id="<%=message.id%>">delete</a>
      </div>
    </div>

    <%- include("../partials/footer.ejs") %>
    <%- include("../partials/deleteButtonScript.ejs") %>
  </body>
</html>
