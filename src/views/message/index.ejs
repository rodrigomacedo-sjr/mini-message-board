<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head.ejs") %>

  <body>
    <%- include("../partials/header.ejs") %> 

    <% if (messages.length <= 0) { %>
      <p>no messages yet...</p>
      <p>be the first to create one!</p>
    <%} %>

    <% messages.forEach((message) => {%>
      <div class="msg-card">
        <p><%=message.content%></p>
        <div class="msg-card-footer">
          <div class="msg-info">
            <p>
              <%= new Date(message.created_at).toLocaleString("pt-BR", {
                day: "2-digit",
                month: "2-digit",
                year: "numeric",
                hour: "2-digit",
                minute: "2-digit"
              }) %>
            </p>

            <p><%=message.sender%></p>
          </div>

          <div class="msg-actions">
            <a href="/message/<%=message.id%>">details</a>
            <a class="delete" data-id="<%=message.id%>">delete</a>
          </div>
        </div>
      </div>
    <%})%>

    <%- include("../partials/footer.ejs") %>
    <%- include("../partials/deleteButtonScript.ejs") %>
  </body>
</html>
